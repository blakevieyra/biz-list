# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local — keep secrets out of git.

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# For npm run db:migrate (Supabase → Settings → Database)
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-us-west-2.pooler.supabase.com:6543/postgres
# — or set SUPABASE_DB_PASSWORD=your-db-password with NEXT_PUBLIC_SUPABASE_URL above

NEXT_PUBLIC_APP_URL=https://all-connect-seven.vercel.app

# Resend (resend.com — free up to 3,000 emails/month)
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=BizList <onboarding@resend.dev>

# ALLOW_DEV_BILLING_BYPASS=true
STRIPE_SECRET_KEY=sk_live_or_sk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_ANNUAL=price_...
STRIPE_PRICE_PLATINUM_MONTHLY=price_...
STRIPE_PRICE_PLATINUM_ANNUAL=price_...
STRIPE_PRICE_CUSTOMER_PLUS_MONTHLY=price_1TlzGd1HZuIni9E7v9zIcTJz
STRIPE_PRICE_CUSTOMER_PLUS_ANNUAL=price_1TlzHH1HZuIni9E75r1IZX4U
