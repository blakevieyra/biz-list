# Create a free project at https://supabase.com
# Copy this file to .env.local and fill in your values.
# Run supabase/full-setup.sql in the Supabase SQL Editor.

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# App URL used in emails and links
NEXT_PUBLIC_APP_URL=https://all-connect-seven.vercel.app

# Email (Resend) — https://resend.com
RESEND_API_KEY=re_your_api_key
EMAIL_FROM=AllConnect <hello@yourdomain.com>

# Optional: Stripe Payment Link for Pro upgrades ($29/mo)
# NEXT_PUBLIC_STRIPE_PAYMENT_LINK=https://buy.stripe.com/your-link
